{
  "preset": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "nodeVersion": "20",
  "kvNamespaces": [
    { "binding": "USERS_KV", "id": "users_kv" },
    { "binding": "SESSIONS_KV", "id": "sessions_kv" },
    { "binding": "PRODUCTS_KV", "id": "products_kv" },
    { "binding": "ORDERS_KV", "id": "orders_kv" }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/assets/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
